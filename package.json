{
	"name": "@dialecte/nsd",
	"version": "0.0.1",
	"description": "Dialecte - NSD (Network Substation Description) sdk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dialecte/nsd.git"
	},
	"source": "src/index.ts",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"//====== BUILD ======//": "",
		"build": "run-p type-check \"build-only {@}\" --",
		"build-only": "tsc -p tsconfig.json && vite build",
		"//====== VITEPRESS ======//": "",
		"doc:dev": "vitepress dev",
		"doc:build": "vitepress build",
		"doc:preview": "vitepress preview",
		"//====== TEST ======//": "",
		"test": "vitest",
		"//====== CHECK ======//": "",
		"check": "run-p type-check lint:check format:check",
		"type-check": "tsc --noEmit",
		"lint:check": "oxlint",
		"lint:fix": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt",
		"//====== HOOKS ======//": "",
		"prepare": "husky"
	},
	"dependencies": {
		"@dialecte/core": "0.2.7"
	},
	"devDependencies": {
		"@tsconfig/node22": "^22.0.2",
		"@types/node": "^22.15.32",
		"@vitest/browser": "^3.2.4",
		"husky": "^9.1.7",
		"jiti": "^2.4.2",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.40.0",
		"oxlint": "^1.55.0",
		"playwright": "^1.53.2",
		"tsx": "^4.20.6",
		"typescript": "~5.8.0",
		"vite": "^8.0.12",
		"vite-plugin-dts": "^4.5.4",
		"vitepress": "^2.0.0-alpha.16",
		"vitest": "^3.2.4",
		"vitest-browser-vue": "^1.0.0"
	}
}
